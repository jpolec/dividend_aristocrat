# QuantJourney API token (required)
QJ_TOKEN=QJ_live_...

# Email transport — Resend (https://resend.com). Without this, emails are only logged to stdout.
RESEND_API_KEY=re_...
DIGEST_FROM=Dividends <onboarding@resend.dev>

# Public URL the unsubscribe link uses (set to your deployed origin)
PUBLIC_BASE_URL=http://localhost:3000

# Optional admin auth — if set, /api/admin/* and /admin require ?token=... or X-Admin-Token header
ADMIN_TOKEN=

# Optional: override SQLite file location
# CACHE_DB=./cache.sqlite

# Optional: override port
# PORT=3000
